# Tumblr app credentials — from https://www.tumblr.com/oauth/apps
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=

# Tumblr user tokens — from https://api.tumblr.com/console
# (paste the consumer key/secret there, authorize, and it shows all four)
TUMBLR_OAUTH_TOKEN=
TUMBLR_OAUTH_TOKEN_SECRET=

# The blog to post to
TUMBLR_BLOG=euphemera.tumblr.com

# Ephemera backend (where jobs are created) and frontend (the render page).
# The frontend must serve a collage.js that has the headless render hook.
EPHEMERA_API_URL=http://localhost:8000
EPHEMERA_FRONTEND_URL=http://localhost:3000

# draft (review first) | queue (drip via blog settings) | published | private
EUPHEMERA_POST_STATE=draft

# screenshot device pixel ratio (1 -> 1600x2200, well under Tumblr limits)
EUPHEMERA_RENDER_SCALE=1
